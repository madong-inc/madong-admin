namespace {namespace};

use core\base\BaseValidate;

/**
 * {class_name}验证器
 *
 * @author Mr.April
 * @since  1.0
 */
class {class_name}Validate extends BaseValidate
{
    /**
     * 场景
     *
     * @var array
     */
    protected array $scene = [
        'store' => [
            {store_fields}
        ],
        'update' => [
            'id',
            {update_fields}
        ],
    ];

    /**
     * 验证规则
     *
     * @return array
     */
    public function rules(): array
    {
        return [
            {rules}
        ];
    }

    /**
     * 错误信息
     *
     * @return array
     */
    public function message(): array
    {
        return [
            {messages}
        ];
    }
}